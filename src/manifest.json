{
  "manifest_version": 3,
  "name": "Debug Dump",
  "version": "1.0.0",
  "description": "One-click dump of full page state (HAR, HTML, console logs) for debugging",
  "permissions": [
    "downloads",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Debug Dump"
  },
  "devtools_page": "devtools/devtools.html",
  "commands": {
    "dump": {
      "suggested_key": { "default": "Alt+Shift+D", "mac": "Alt+Shift+D" },
      "description": "Dump current page state"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}
